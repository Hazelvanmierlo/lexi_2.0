# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# lexi: prisma local sqlite (only used for quick experiments)
prisma/*.db
prisma/*.db-journal

# extracted video reference frames (local-only)
/.video_frames/

# playwright screenshots from local audit (local-only)
/landing-*.png
/.playwright-mcp/

# generated test/audit artifacts
/test-results/
/.lighthouseci/
/playwright-report/
