# Database (Postgres on Neon or Supabase)
DATABASE_URL=

# Auth — Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Payments — Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Analytics — PostHog (EU host because Dutch/Belgian users)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth — Clerk (per docs/superpowers/specs/2026-05-12-lexi-auth-design.md)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=

# Cutover flag — set true once auth is ready in prod
NEXT_PUBLIC_AUTH_ENABLED=false

# 32-byte random base64 secret for signing the pickedKidId cookie
COOKIE_SECRET=
